<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <link rel="stylesheet" href="/customer/customer.css"/>
  <title>Order Detail</title>
</head>
<body>
  <div class="container">
    <div class="topbar">
      <a class="pill" href="/c/orders">← My Orders</a>
      <div class="h1">Order #<%= order.id %></div>
      <a class="pill" href="/c/cart">Cart</a>
    </div>

    <div class="card">
      <div class="h1" style="font-size:16px;">Status</div>

      <% const os = String(order.order_status || '').toUpperCase(); %>
      <% const fs = String(order.fulfillment_status || '').toUpperCase(); %>

      <div class="timeline" style="margin-top:10px;">
        <span class="dot on"></span><span class="muted">Placed</span>

        <span class="dot <%= (os === 'ACTIVE' || os === 'CLOSED') ? 'on' : '' %>"></span>
        <span class="muted">Confirmed</span>

        <span class="dot <%= (fs === 'DISPATCHED' || fs === 'DELIVERED' || os === 'CLOSED') ? 'on' : '' %>"></span>
        <span class="muted">Dispatched</span>

        <span class="dot <%= (fs === 'DELIVERED' || os === 'CLOSED') ? 'on' : '' %>"></span>
        <span class="muted">Delivered</span>
      </div>

      <div style="margin-top:10px;" class="pill">
        Current: <%= order.status_display || (order.order_status || order.status) %>
      </div>

      <div style="margin-top:10px;" class="row">
        <span class="pill"><%= (String(order.payment_status||'').toUpperCase()==='PAID') ? 'Paid' : 'Unpaid' %></span>
        <span class="pill">Total: ₹<%= order.total %></span>
      </div>
    </div>

      <% if (String(order.payment_method||"").toUpperCase()==="UPI" && String(order.payment_status||"").toUpperCase()!=="PAID") { %>
        <div class="card" style="margin-top:12px;">
          <div class="h1" style="font-size:16px;">UPI Payment</div>
          <div class="muted" style="margin-top:6px;">After payment, enter UTR to confirm.</div>

          <form method="POST" action="/c/orders/<%= order.id %>/upi-confirm" style="margin-top:10px;">
            <input name="payment_utr" placeholder="Enter UTR (12-22 digits)" style="width:100%;padding:12px;border-radius:14px;border:1px solid var(--border);" />
            <button class="btn block primary" type="submit" style="margin-top:10px;">I have paid (Submit UTR)</button>
          </form>

          <div class="muted" style="margin-top:8px;">Status becomes: PENDING_VERIFICATION (admin will mark PAID)</div>
        </div>
      <% } %>

    <div class="card">
      <div class="h1" style="font-size:16px;">Items</div>
      <div class="list" style="margin-top:10px;">
        <% items.forEach(i => { %>
          <div class="item">
            <div>
              <div style="font-weight:900;"><%= i.product_name %> • <%= i.sub_name %></div>
              <div class="muted">₹<%= i.price %> × <%= i.quantity %></div>
            </div>
            <div class="pill">x<%= i.quantity %></div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</body>
</html>

